{
  "name": "Matter",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "dotenv -- turbo run dev",
    "infra:up": "dotenv -- docker compose -f infra/docker/dev.compose.yaml up -d",
    "infra:down": "dotenv -- docker compose -f infra/docker/dev.compose.yaml down",
    "db:migrate": "dotenv -- pnpm --filter @matterchat/database run db:migrate",
    "db:generate": "dotenv -- turbo run db:generate",
    "db:studio": "dotenv -- pnpm --filter @matterchat/database run db:studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.6.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "turbo": "^2.10.4"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  }
}
